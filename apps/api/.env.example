# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://localhost:19006

# Database
DATABASE_URL=postgresql://medicontrol:medicontrol_dev_password@localhost:5432/medicontrol_dev?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (CAMBIAR EN PRODUCCION - generar con: openssl rand -hex 64)
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production_min_64_chars_xxxxxxxxxxxxxx
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_in_production_min_64_chars_xxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Storage S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=mx-central-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_RECEIPTS=medicontrol-receipts-dev
S3_BUCKET_PRESCRIPTIONS=medicontrol-prescriptions-dev
S3_BUCKET_CONSENTS=medicontrol-consents-dev
S3_ACCESS_KEY=medicontrol
S3_SECRET_KEY=medicontrol_dev_password

# Feature flags (override por env)
FEATURE_MERCADOPAGO_ENABLED=false

# WhatsApp (proximamente)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
