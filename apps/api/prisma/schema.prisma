// Prisma schema - MediControl Sprint 1
// Multi-tenant desde dia 1. Toda tabla operativa lleva organizationId.
// Convencion: PascalCase en modelos, snake_case en BD via @@map / @map.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, citext, pg_trgm, btree_gist]
}

// ============================================================================
// TENANT ROOT
// ============================================================================

enum OrgType {
  CLINIC
  MEDICAL_GROUP
  HOSPITAL
}

model Organization {
  id            String   @id @default(uuid()) @db.Uuid
  legalName     String   @map("legal_name") @db.VarChar(255)
  rfc           String   @db.VarChar(13)
  orgType       OrgType  @default(CLINIC) @map("org_type")
  fiscalAddress Json     @map("fiscal_address") @db.JsonB
  timezone      String   @default("America/Mexico_City") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  branches           Branch[]
  users              User[]
  persons            Person[]
  doctors            Doctor[]
  patients           Patient[]
  roles              Role[]
  featureFlags       FeatureFlag[]
  refreshTokens      RefreshToken[]
  accessLogs         AccessLog[]
  services           Service[]
  appointments       Appointment[]
  serviceLocations   ServiceLocation[]
  schedules          Schedule[]
  scheduleExceptions ScheduleException[]
  medicalRecords     MedicalRecord[]
  clinicalNotes      ClinicalNote[]
  vitalSigns         VitalSign[]
  diagnoses          Diagnosis[]
  treatments         Treatment[]
  informedConsents   InformedConsent[]
  labOrders          LabOrder[]
  labProviders       LabProvider[]
  prescriptions      Prescription[]
  payments           Payment[]
  medications        Medication[]
  inventoryBatches   InventoryBatch[]
  stockMovements     StockMovement[]
  sales              Sale[]
  dispensings        Dispensing[]
  reportSchedules    ReportSchedule[]
  notifications      Notification[]
  notificationTemplates NotificationTemplate[]
  notificationLogs   NotificationLog[]
  cashRegisters      CashRegister[]

  @@map("organizations")
}

model Branch {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  code            String   @db.VarChar(20)
  name            String   @db.VarChar(255)
  address         Json     @db.JsonB
  phone           String?  @db.VarChar(20)
  cofeprisLicense String?  @map("cofepris_license") @db.VarChar(50)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceLocations ServiceLocation[]
  userRoles        UserRole[]
  appointments     Appointment[]
  payments         Payment[]
  sales            Sale[]
  cashRegisters    CashRegister[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

enum ServiceLocationType {
  EXAM_ROOM
  OR
  BED
  ER_BAY
  PROCEDURE
  LAB
  IMAGING
}

model ServiceLocation {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  branchId       String              @map("branch_id") @db.Uuid
  code           String              @db.VarChar(20)
  name           String              @db.VarChar(120)
  locationType   ServiceLocationType @default(EXAM_ROOM) @map("location_type")
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  schedules    Schedule[]

  @@unique([branchId, code])
  @@index([organizationId])
  @@map("service_locations")
}

// ============================================================================
// IDENTIDAD / RBAC
// ============================================================================

enum UserStatus {
  ACTIVE
  INVITED
  LOCKED
  DISABLED
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  organizationId     String     @map("organization_id") @db.Uuid
  personId           String?    @unique @map("person_id") @db.Uuid
  email              String     @db.Citext
  phoneE164          String?    @map("phone_e164") @db.VarChar(20)
  passwordHash       String?    @map("password_hash") @db.VarChar(255)
  mfaSecretEnc       Bytes?     @map("mfa_secret_enc")
  mfaEnabled         Boolean    @default(false) @map("mfa_enabled")
  status             UserStatus @default(ACTIVE)
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz
  failedAttempts     Int        @default(0) @map("failed_attempts") @db.SmallInt
  lockedUntil        DateTime?  @map("locked_until") @db.Timestamptz
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person        Person?        @relation(fields: [personId], references: [id])
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  accessLogs    AccessLog[]
  doctor        Doctor?
  clinicalNotes ClinicalNote[]
  diagnoses     Diagnosis[]
  treatments    Treatment[]
  witnessedConsents InformedConsent[] @relation("witnessedConsents")
  labOrders     LabOrder[]
  labResults    LabResult[]
  patient       Patient?
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  sales               Sale[]
  cashRegistersOpened CashRegister[]    @relation("openedBy")
  cashRegistersClosed CashRegister[]    @relation("closedBy")
  cashMovements       CashMovement[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

enum Gender {
  M
  F
  X
}

model Person {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  firstName      String   @map("first_name") @db.VarChar(120)
  lastNameP      String   @map("last_name_p") @db.VarChar(120)
  lastNameM      String?  @map("last_name_m") @db.VarChar(120)
  curp           String?  @db.VarChar(18)
  rfc            String?  @db.VarChar(13)
  birthDate      DateTime @map("birth_date") @db.Date
  gender         Gender
  nationality    String?  @db.VarChar(50)
  ethnicGroup    String?  @map("ethnic_group") @db.VarChar(80)
  occupation     String?  @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?
  doctor       Doctor?
  patient      Patient?

  @@unique([organizationId, curp])
  @@index([organizationId])
  @@map("persons")
}

model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(40)
  name           String   @db.VarChar(120)
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, code])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  description String?
  resource    String   @db.VarChar(40)
  action      String   @db.VarChar(40)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_roles")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.VarChar(255)
  family         String    @db.Uuid
  userAgent      String?   @map("user_agent") @db.Text
  ipAddress      String?   @map("ip_address") @db.Inet
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz
  replacedById   String?   @map("replaced_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ============================================================================
// FEATURE FLAGS (motor de pagos dormant, etc.)
// ============================================================================

// ============================================================================
// RECUPERACION DE CONTRASENA (Sprint 7)
// ============================================================================

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model FeatureFlag {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  flagKey        String    @map("flag_key") @db.VarChar(80)
  enabled        Boolean   @default(false)
  payload        Json      @default("{}") @db.JsonB
  activatedAt    DateTime? @map("activated_at") @db.Timestamptz
  activatedBy    String?   @map("activated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, flagKey])
  @@map("feature_flags")
}

// ============================================================================
// BITACORA DE ACCESO (NOM-024 + LFPDPPP)
// ============================================================================

enum AccessAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  READ
  CREATE
  UPDATE
  DELETE
  SIGN
  EXPORT
  MFA_ENABLED
  MFA_DISABLED
  PASSWORD_CHANGED
}

model AccessLog {
  id             BigInt       @id @default(autoincrement())
  organizationId String?      @map("organization_id") @db.Uuid
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  targetUserId   String?      @map("target_user_id") @db.Uuid
  resourceType   String?      @map("resource_type") @db.VarChar(40)
  resourceId     String?      @map("resource_id") @db.VarChar(64)
  action         AccessAction
  reason         String?      @db.VarChar(120)
  ipAddress      String?      @map("ip_address") @db.Inet
  userAgent      String?      @map("user_agent") @db.Text
  metadata       Json?        @db.JsonB
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("access_log")
}

// ============================================================================
// MEDICOS / PACIENTES (stubs S1 - se expanden en S2)
// ============================================================================

model Doctor {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  userId             String?  @unique @map("user_id") @db.Uuid
  personId           String   @unique @map("person_id") @db.Uuid
  cedulaProfesional  String   @map("cedula_profesional") @db.VarChar(20)
  cedulaEspecialidad String?  @map("cedula_especialidad") @db.VarChar(20)
  specialtyCode      String   @map("specialty_code") @db.VarChar(20)
  councilCertified   Boolean  @default(false) @map("council_certified")
  signatureImageUrl  String?  @map("signature_image_url") @db.Text
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  person             Person              @relation(fields: [personId], references: [id], onDelete: Restrict)
  appointments       Appointment[]
  schedules          Schedule[]
  scheduleExceptions ScheduleException[]
  prescriptions      Prescription[]

  @@unique([organizationId, cedulaProfesional])
  @@index([organizationId])
  @@map("doctors")
}

model Patient {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  userId            String?   @unique @map("user_id") @db.Uuid
  personId          String    @unique @map("person_id") @db.Uuid
  mrn               String    @db.VarChar(20)
  bloodType         String?   @map("blood_type") @db.VarChar(5)
  emergencyContact  Json?     @map("emergency_contact") @db.JsonB
  insurance         Json?     @db.JsonB
  preferredLanguage String    @default("es-MX") @map("preferred_language") @db.VarChar(10)
  consentPrivacyAt  DateTime? @map("consent_privacy_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  person       Person            @relation(fields: [personId], references: [id], onDelete: Restrict)
  appointments Appointment[]
  medicalRecord MedicalRecord?
  signedConsents InformedConsent[]
  prescriptions  Prescription[]
  payments       Payment[]
  sales          Sale[]

  @@unique([organizationId, mrn])
  @@index([organizationId])
  @@map("patients")
}

// ============================================================================
// CATALOGO DE SERVICIOS Y CITAS (stubs S1 - se expanden en S3)
// ============================================================================

model Service {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String   @db.VarChar(40)
  name           String   @db.VarChar(255)
  description    String?
  durationMin    Int      @default(30) @map("duration_min") @db.SmallInt
  defaultPrice   Decimal  @map("default_price") @db.Decimal(12, 2)
  currency       String   @default("MXN") @db.VarChar(3)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("services")
}

enum AppointmentStatus {
  PENDING_DOCTOR_CONFIRMATION
  SCHEDULED
  PAYMENT_PENDING_VALIDATION
  PAID
  CHECKED_IN
  IN_TRIAGE
  IN_CONSULT
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
}

enum PaymentMethod {
  CASH
  POS
  SPEI
  MERCADO_PAGO
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Appointment {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  branchId          String            @map("branch_id") @db.Uuid
  serviceLocationId String?           @map("service_location_id") @db.Uuid
  doctorId          String            @map("doctor_id") @db.Uuid
  patientId         String            @map("patient_id") @db.Uuid
  serviceId         String            @map("service_id") @db.Uuid
  startsAt          DateTime          @map("starts_at") @db.Timestamptz
  endsAt            DateTime          @map("ends_at") @db.Timestamptz
  status            AppointmentStatus @default(SCHEDULED)
  reason            String?
  channel           String            @db.VarChar(20)
  priceQuoted       Decimal           @map("price_quoted") @db.Decimal(12, 2)
  currency          String            @default("MXN") @db.VarChar(3)
  createdByUserId   String?           @map("created_by_user_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  serviceLocation ServiceLocation?      @relation(fields: [serviceLocationId], references: [id], onDelete: SetNull)
  doctor          Doctor                @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Restrict)
  service         Service               @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  reminders       AppointmentReminder[]
  clinicalNotes   ClinicalNote[]
  vitalSigns      VitalSign[]
  diagnoses       Diagnosis[]
  payments        Payment[]

  @@index([organizationId, startsAt])
  @@index([doctorId, startsAt])
  @@index([patientId, startsAt])
  @@map("appointments")
}

// ============================================================================
// PAGOS (Sprint 5)
// ============================================================================

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  branchId        String        @map("branch_id") @db.Uuid
  appointmentId   String?       @map("appointment_id") @db.Uuid
  patientId       String        @map("patient_id") @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("MXN") @db.VarChar(3)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  reference       String?       @map("reference") @db.VarChar(120)
  gatewayResponse Json?         @map("gateway_response") @db.JsonB
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz
  createdByUserId String        @map("created_by_user_id") @db.Uuid
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([appointmentId])
  @@index([patientId])
  @@index([status])
  @@map("payments")
}

// ============================================================================
// AGENDA - HORARIOS (Sprint 3)
// ============================================================================

model Schedule {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  doctorId          String   @map("doctor_id") @db.Uuid
  serviceLocationId String?  @map("service_location_id") @db.Uuid
  dayOfWeek         Int      @map("day_of_week") @db.SmallInt
  startTime         DateTime @map("start_time") @db.Time
  endTime           DateTime @map("end_time") @db.Time
  slotDurationMin   Int      @default(30) @map("slot_duration_min") @db.SmallInt
  isActive          Boolean  @default(true) @map("is_active")
  maxPatients       Int?     @default(0) @map("max_patients") @db.SmallInt
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor          Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceLocation ServiceLocation? @relation(fields: [serviceLocationId], references: [id], onDelete: SetNull)

  @@index([doctorId, dayOfWeek])
  @@index([organizationId])
  @@map("schedules")
}

model ScheduleException {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  doctorId       String    @map("doctor_id") @db.Uuid
  exceptionDate  DateTime  @map("exception_date") @db.Date
  startTime      DateTime? @map("start_time") @db.Time
  endTime        DateTime? @map("end_time") @db.Time
  isAvailable    Boolean   @default(false) @map("is_available")
  reason         String?   @db.VarChar(255)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, exceptionDate])
  @@index([organizationId])
  @@map("schedule_exceptions")
}

model AppointmentReminder {
  id            String    @id @default(uuid()) @db.Uuid
  appointmentId String    @map("appointment_id") @db.Uuid
  reminderType  String    @map("reminder_type") @db.VarChar(20)
  scheduledFor  DateTime  @map("scheduled_for") @db.Timestamptz
  sentAt        DateTime? @map("sent_at") @db.Timestamptz
  status        String    @default("PENDING") @db.VarChar(20)
  errorMessage  String?   @map("error_message") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_reminders")
}

// ============================================================================
// EXPEDIENTE CLINICO (NOM-004-SSA3-2012)
// ============================================================================

enum DiagnosisType {
  PRINCIPAL
  SECONDARY
  DIFFERENTIAL
}

enum DiagnosisStatus {
  ACTIVE
  RESOLVED
  SUSPECTED
}

enum TreatmentType {
  PHARMACOLOGICAL
  NON_PHARMACOLOGICAL
  SURGICAL
}

enum TreatmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum ConsentType {
  GENERAL
  SURGERY
  ANESTHESIA
  BLOOD_TRANSFUSION
  RESEARCH
  OTHERS
}

enum StudyType {
  LABORATORY
  IMAGING
  PATHOLOGY
  OTHER
}

enum LabOrderStatus {
  PENDING
  COLLECTED
  IN_PROGRESS
