model Medication {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  sku                  String   @db.VarChar(40)
  barcode              String?  @db.VarChar(30)
  name                 String   @db.VarChar(255)
  description          String?  @db.Text
  presentation         String   @db.VarChar(100)
  activeIngredient     String?  @map("active_ingredient") @db.VarChar(255)
  concentration        String?  @db.VarChar(50)
  requiresPrescription Boolean  @default(false) @map("requires_prescription")
