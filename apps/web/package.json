{
  "name": "@medicontrol/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portal web administrativo y para medicos - MediControl",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:capacitor": "vite build --base ./",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo node_modules/.vite",
    "cap:sync": "pnpm build:capacitor && npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@hookform/resolvers": "^3.9.1",
    "@medicontrol/brand": "workspace:*",
    "@tanstack/react-query": "^5.59.20",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.4"
  }
}
