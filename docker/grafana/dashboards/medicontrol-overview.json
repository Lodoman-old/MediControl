{
  "title": "MediControl - Overview",
  "uid": "medicontrol-overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "HTTP Requests Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(medicontrol_http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "HTTP Request Duration (p95)",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(medicontrol_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Active Users",
      "type": "stat",
      "targets": [{ "expr": "medicontrol_active_users" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }
    },
    {
      "title": "DB Query Duration (avg)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(medicontrol_db_query_duration_seconds_sum[5m]) / rate(medicontrol_db_query_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 }
    },
    {
      "title": "Appointments Created",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(medicontrol_appointments_total[5m])",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 18, "y": 8 }
    },
    {
      "title": "In-Flight Requests",
      "type": "stat",
      "targets": [{ "expr": "medicontrol_http_requests_in_flight" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 }
    },
    {
      "title": "Node.js Memory Usage",
      "type": "graph",
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS" },
        { "expr": "process_heap_bytes", "legendFormat": "Heap" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "CPU Usage",
      "type": "graph",
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[5m])", "legendFormat": "CPU" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
