{
  "name": "medicontrol",
  "version": "0.1.0",
  "private": true,
  "description": "MediControl - Sistema de gestion de consultorio medico escalable a HIS",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @medicontrol/web dev",
    "dev:api": "pnpm --filter @medicontrol/api dev:all",
    "dev:mobile": "pnpm --filter @medicontrol/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "playwright": "^1.61.0"
  }
}
